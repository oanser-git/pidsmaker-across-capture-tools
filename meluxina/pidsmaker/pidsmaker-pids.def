Bootstrap: docker
From: pytorch/pytorch:1.13.1-cuda11.6-cudnn8-runtime

%environment
    export PATH=/opt/conda/bin:$PATH
    export NLTK_DATA=/opt/nltk_data
    export PYTHONUNBUFFERED=1

%post
    export DEBIAN_FRONTEND=noninteractive
    export PATH=/opt/conda/bin:$PATH
    export NLTK_DATA=/opt/nltk_data

    apt-get update
    apt-get install -y --no-install-recommends ca-certificates graphviz git
    rm -rf /var/lib/apt/lists/*

    python -m pip install --no-cache-dir --upgrade pip
    python -m pip install --no-cache-dir \
        numpy==1.26.4 \
        scipy==1.10.1 \
        scikit-learn==1.2.0 \
        networkx==2.8.7 \
        xxhash==3.2.0 \
        graphviz==0.20.1 \
        psutil \
        matplotlib==3.8.4 \
        wandb==0.24.1 \
        chardet==5.2.0 \
        nltk==3.8.1 \
        igraph==0.11.5 \
        cairocffi==1.7.0 \
        wget==3.2 \
        gensim==4.3.1 \
        pytz==2024.1 \
        pandas==2.2.2 \
        PyYAML==6.0.2 \
        yacs==0.1.8 \
        gdown==5.2.0

    python -m pip install --no-cache-dir torch_geometric==2.5.3
    python -m pip install --no-cache-dir \
        pyg_lib==0.2.0 \
        torch_scatter==2.1.1 \
        torch_sparse==0.6.17 \
        torch_cluster==1.6.1 \
        torch_spline_conv==1.2.2 \
        -f https://data.pyg.org/whl/torch-1.13.0+cu117.html

    mkdir -p /opt/nltk_data
    python - <<'PY'
import nltk
nltk.download("punkt", download_dir="/opt/nltk_data", quiet=True)
PY

%test
    python - <<'PY'
import networkx
import pandas
import sklearn
import torch
import torch_geometric
import yaml
import yacs
print("PIDSMaker image test ok")
PY
